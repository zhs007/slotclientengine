{
  "name": "@slotclientengine/rendercore",
  "version": "0.1.0",
  "private": true,
  "description": "Internal PixiJS render core for slotclientengine.",
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./symbol": {
      "types": "./dist/symbol/index.d.ts",
      "import": "./dist/symbol/index.js"
    },
    "./background": {
      "types": "./dist/background/index.d.ts",
      "import": "./dist/background/index.js"
    },
    "./reel": {
      "types": "./dist/reel/index.d.ts",
      "import": "./dist/reel/index.js"
    },
    "./viewport": {
      "types": "./dist/viewport/index.d.ts",
      "import": "./dist/viewport/index.js"
    },
    "./scene-layout": {
      "types": "./dist/scene-layout/index.d.ts",
      "import": "./dist/scene-layout/index.js"
    },
    "./image-string": {
      "types": "./dist/image-string/index.d.ts",
      "import": "./dist/image-string/index.js"
    },
    "./symbol-image-string": {
      "types": "./dist/symbol-image-string/index.d.ts",
      "import": "./dist/symbol-image-string/index.js"
    },
    "./win-amount": {
      "types": "./dist/win-amount/index.d.ts",
      "import": "./dist/win-amount/index.js"
    },
    "./popup": {
      "types": "./dist/popup/index.d.ts",
      "import": "./dist/popup/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare:deps": "pnpm --filter @slotclientengine/browserartifactio build && pnpm --filter @slotclientengine/editorresource build && pnpm --filter @slotclientengine/logiccore build && pnpm --filter @slotclientengine/pixiani build && pnpm --filter @slotclientengine/vnicore build",
    "build": "pnpm run prepare:deps && tsc -p tsconfig.build.json",
    "generate:symbol-state-textures": "node ./scripts/generate-symbol-state-textures.mjs",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "typecheck": "pnpm run prepare:deps && tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "~4.3.10",
    "@slotclientengine/browserartifactio": "workspace:*",
    "@slotclientengine/editorresource": "workspace:*",
    "@slotclientengine/logiccore": "workspace:*",
    "@slotclientengine/pixiani": "workspace:*",
    "@slotclientengine/vnicore": "workspace:*",
    "pixi.js": "^8.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.15.0",
    "sharp": "^0.34.4"
  }
}
