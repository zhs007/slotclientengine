{
  "name": "[projname]",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "turbo run build:app",
    "prebuild:app": "rm -rf dist",
    "build:app": "vite build",
    "test:prod": "vite build && vite preview",
    "test": "turbo run test:run",
    "test:run": "vitest run --coverage",
    "lint": "turbo run lint:app",
    "lint:app": "eslint \"src/**/*.{ts,js}\" \"tests/**/*.ts\"",
    "typecheck": "turbo run typecheck:app",
    "typecheck:app": "tsc -p tsconfig.json --noEmit",
    "format": "turbo run format:app",
    "format:app": "prettier --write \"src/**/*.{ts,js}\" \"tests/**/*.ts\" \"index.html\" \"README.md\""
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "pixi.js": "^8.1.6"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
